<?xml version="1.0" encoding="UTF-8"?>
<!--
  Boomi Process : XmlToJson_ShipmentNotification
  Pattern       : XML -> JSON
  Env Variables : None

  Ideal SFTP file listing (sftp.supplier.example.com:/outbound/shipments/):
    shipments_20241219.xml  (contains multiple <Shipment> elements)

  Ideal Tracking API Response (POST https://logistics.example.com/api/tracking):
  HTTP 200 OK
  {
    "status": "received",
    "shipmentId": "SHP-88901",
    "trackingUrl": "https://logistics.example.com/track/SHP-88901"
  }
-->
<process xmlns="http://api.platform.boomi.com/"
         componentId="55555555-eeee-4000-8000-000000000001"
         name="XmlToJson_ShipmentNotification"
         processName="XmlToJson_ShipmentNotification"
         platform="Dell Boomi"
         version="1.0">

  <shape id="start_scheduler"
         name="Daily Schedule 03:00 UTC"
         type="start"
         shapeType="start.scheduler"
         cron="0 0 3 * * ?"/>

  <shape id="connector_sftp_get"
         name="Get Shipment XML from SFTP"
         type="connectorAction"
         shapeType="connector.sftp"
         host="sftp.supplier.example.com"
         port="22"
         remotePath="/outbound/shipments/*.xml"
         sampleInput='&lt;ShipmentNotifications&gt;
           &lt;Shipment&gt;
             &lt;ShipmentId&gt;SHP-88901&lt;/ShipmentId&gt;
             &lt;OrderId&gt;ORD-2024-0042&lt;/OrderId&gt;
             &lt;CarrierCode&gt;FEDEX&lt;/CarrierCode&gt;
             &lt;TrackingNumber&gt;7489203847561&lt;/TrackingNumber&gt;
             &lt;Status&gt;IN_TRANSIT&lt;/Status&gt;
             &lt;EstimatedDelivery&gt;2024-12-20&lt;/EstimatedDelivery&gt;
           &lt;/Shipment&gt;
           &lt;Shipment&gt;
             &lt;ShipmentId&gt;SHP-88902&lt;/ShipmentId&gt;
             &lt;OrderId&gt;ORD-2024-0043&lt;/OrderId&gt;
             &lt;CarrierCode&gt;&lt;/CarrierCode&gt;
             &lt;TrackingNumber&gt;&lt;/TrackingNumber&gt;
             &lt;Status&gt;PENDING&lt;/Status&gt;
             &lt;EstimatedDelivery&gt;&lt;/EstimatedDelivery&gt;
           &lt;/Shipment&gt;
         &lt;/ShipmentNotifications&gt;'/>

  <shape id="data_process_split"
         name="Split per Shipment Element"
         type="dataProcess"
         action="Split"
         splitElement="/ShipmentNotifications/Shipment"/>

  <shape id="data_process_xml_to_profile"
         name="Parse XML to Profile"
         type="dataProcess"
         action="XMLToProfile"/>

  <shape id="map_xml_to_json"
         name="Map XML Shipment -> JSON Tracking"
         type="map"
         mappings="ShipmentId->shipmentId;OrderId->orderId;CarrierCode->carrierCode;TrackingNumber->trackingNumber;Status->status;EstimatedDelivery->estimatedDelivery"
         sampleOutput='{
           "shipmentId": "SHP-88901",
           "orderId": "ORD-2024-0042",
           "carrierCode": "FEDEX",
           "trackingNumber": "7489203847561",
           "status": "IN_TRANSIT",
           "estimatedDelivery": "2024-12-20"
         }'/>

  <shape id="decision_has_carrier"
         name="Carrier Code Present?"
         type="decision"
         expression="carrierCode is not null and carrierCode != ''"/>

  <shape id="connector_tracking_post"
         name="POST JSON to Tracking API"
         type="connectorAction"
         shapeType="connector.http"
         url="https://logistics.example.com/api/tracking"
         httpMethod="POST"
         contentType="application/json"/>

  <shape id="notify_missing_carrier"
         name="Log Missing Carrier"
         type="notify"
         level="WARNING"
         message="Shipment $shipmentId has no carrier code — skipped."/>

  <shape id="notify_summary"
         name="Run Summary"
         type="notify"
         level="INFO"
         message="Shipment sync complete. Documents processed: $document.count"/>

  <connection source="start_scheduler"            target="connector_sftp_get"/>
  <connection source="connector_sftp_get"         target="data_process_split"/>
  <connection source="data_process_split"         target="data_process_xml_to_profile"/>
  <connection source="data_process_xml_to_profile" target="map_xml_to_json"/>
  <connection source="map_xml_to_json"             target="decision_has_carrier"/>
  <connection source="decision_has_carrier"        target="connector_tracking_post"  label="true"/>
  <connection source="decision_has_carrier"        target="notify_missing_carrier"   label="false"/>
  <connection source="connector_tracking_post"     target="notify_summary"/>
  <connection source="notify_missing_carrier"      target="notify_summary"/>

</process>
