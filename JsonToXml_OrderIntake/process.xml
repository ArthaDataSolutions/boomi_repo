<?xml version="1.0" encoding="UTF-8"?>
<process xmlns="http://api.platform.boomi.com/"
         componentId="11111111-aaaa-4000-8000-000000000001"
         name="JsonToXml_OrderIntake"
         processName="JsonToXml_OrderIntake"
         platform="Dell Boomi"
         version="1.0">

  <shape id="start_listener"
         name="Receive JSON Order (Web Services Listener)"
         type="start"
         shapeType="start.webservices"
         componentRef="11111111-aaaa-4000-8000-000000000050"/>

  <shape id="set_correlation_id"
         name="Set Correlation Properties"
         type="setProperties"
         componentRef="11111111-aaaa-4000-8000-000000000060"/>

  <shape id="data_process_parse_json"
         name="Parse Inbound JSON"
         type="dataProcess"
         action="JSONToProfile"
         profileRef="11111111-aaaa-4000-8000-000000000020"/>

  <shape id="map_json_to_cxml"
         name="Map JSON Order -> cXML OrderRequest"
         type="map"
         componentRef="11111111-aaaa-4000-8000-000000000030"/>

  <shape id="connector_erp_http"
         name="POST cXML to SAP ERP"
         type="connectorAction"
         shapeType="connector.http"
         connectionRef="11111111-aaaa-4000-8000-000000000010"
         operationRef="11111111-aaaa-4000-8000-000000000011"/>

  <shape id="decision_http_status"
         name="HTTP 2xx?"
         type="decision"
         expression="document.dynamic.userdefined.statusCode startsWith '2'"/>

  <shape id="notify_success"
         name="Notify Success"
         type="notify"
         level="INFO"
         message="Order accepted by ERP for correlationId=$correlation.id"/>

  <shape id="notify_failure"
         name="Route to DLQ + Alert"
         type="notify"
         level="ERROR"
         message="ERP rejected order $correlation.id status=$statusCode"
         emailRecipients="integration-ops@acmecorp.com"/>

  <shape id="return_documents"
         name="Return ACK to Caller"
         type="returnDocuments"
         profileRef="11111111-aaaa-4000-8000-000000000022"/>

  <connection source="start_listener"          target="set_correlation_id"/>
  <connection source="set_correlation_id"      target="data_process_parse_json"/>
  <connection source="data_process_parse_json" target="map_json_to_cxml"/>
  <connection source="map_json_to_cxml"        target="connector_erp_http"/>
  <connection source="connector_erp_http"      target="decision_http_status"/>
  <connection source="decision_http_status"    target="notify_success"  label="true"/>
  <connection source="decision_http_status"    target="notify_failure"  label="false"/>
  <connection source="notify_success"          target="return_documents"/>
  <connection source="notify_failure"          target="return_documents"/>

</process>
