# =====================================================================
# Environment overrides for the Dell Boomi sample processes.
# Every variable below corresponds to a ${PLACEHOLDER} in one of the
# extensions.xml files. Copy to `.env` and fill in real values before
# deploying the converted Python flows.
# =====================================================================

# ---------------------------------------------------------------------
# JsonToXml_OrderIntake
# ---------------------------------------------------------------------
ERP_BASE_URL=https://erp.internal.acmecorp.com
ERP_BASIC_USER=integration_svc
ERP_BASIC_PASSWORD=change-me
WS_LISTENER_BASE_PATH=/ws/orders
OPS_ALERT_EMAIL=integration-ops@acmecorp.com

# ---------------------------------------------------------------------
# XmlToJson_PartnerCatalogSync
# ---------------------------------------------------------------------
SFTP_HOST=sftp.supplier-northwind.com
SFTP_PORT=22
SFTP_USER=acme-catalog
SFTP_PRIVATE_KEY=/etc/secrets/sftp_id_ed25519
SFTP_REMOTE_DIR=/outbound/catalog

STOREFRONT_BASE_URL=https://api.shop.acmecorp.com
STOREFRONT_OAUTH_TOKEN_URL=https://auth.shop.acmecorp.com/oauth2/token
STOREFRONT_OAUTH_CLIENT_ID=storefront-ingest
STOREFRONT_OAUTH_CLIENT_SECRET=change-me

# ---------------------------------------------------------------------
# OAuthApi_CustomerSync
# ---------------------------------------------------------------------
CRM_OAUTH_TOKEN_URL=https://login.crm.example.com/oauth2/token
CRM_CLIENT_ID=acme-warehouse-sync
CRM_CLIENT_SECRET=change-me
CRM_OAUTH_SCOPE=customers.read
CRM_API_BASE_URL=https://api.crm.example.com
CRM_LAST_RUN_DEFAULT_ISO=1970-01-01T00:00:00Z

DW_POSTGRES_HOST=dw-postgres-prod.internal.acmecorp.com
DW_POSTGRES_PORT=5432
DW_POSTGRES_DB=warehouse
DW_POSTGRES_USER=etl_writer
DW_POSTGRES_PASSWORD=change-me
