<?xml version="1.0" encoding="UTF-8"?>
<!--
  Dell Boomi Process: XmlToJson_PartnerCatalogSync
  Use case: Nightly pull of supplier product catalog XML feeds from an SFTP
  drop, transform each record to JSON, and POST to the e-commerce REST API
  used by the storefront search index.

  Pattern: Scheduled SFTP -> XML profile -> Map -> JSON REST POST.
  Common in retail / distribution where suppliers publish XML catalogs but
  downstream cloud systems consume JSON.
-->
<process name="XmlToJson_PartnerCatalogSync" platform="Dell Boomi" version="1.0">

  <shape id="start_scheduler"
         name="Nightly Schedule 02:15 UTC"
         type="start"
         shapeType="start.scheduler"
         cron="0 15 2 * * ?"/>

  <shape id="connector_sftp_get"
         name="Get Catalog XML from Supplier SFTP"
         type="connectorAction"
         shapeType="connector.sftp"
         action="GET"
         host="sftp.supplier-northwind.com"
         port="22"
         remoteDir="/outbound/catalog"
         filePattern="catalog_*.xml"
         deleteAfterRead="false"
         archiveDir="/archive"/>

  <shape id="data_process_split"
         name="Split per &lt;Product&gt; Element"
         type="dataProcess"
         action="Split"
         splitProfile="XML_SupplierCatalog_v3"
         splitElement="/Catalog/Product"/>

  <shape id="data_process_xml_to_profile"
         name="Parse XML to Profile"
         type="dataProcess"
         action="XMLToProfile"
         inboundProfile="XML_SupplierCatalog_v3"/>

  <shape id="map_xml_to_json"
         name="Map XML Product -> JSON CatalogItem"
         type="map"
         sourceProfile="XML_SupplierCatalog_v3"
         targetProfile="JSON_CatalogItem_v2"
         mapping="Product/@sku=>sku,
                  Product/Name=>name,
                  Product/Pricing/Price[@currency='USD']=>price.amount,
                  Product/Pricing/Price/@currency=>price.currency,
                  Product/Stock/OnHand=>inventory.onHand,
                  Product/Categories/Category[*]=>categories,
                  functions.now()=>ingestedAt"/>

  <shape id="decision_in_stock"
         name="In Stock?"
         type="decision"
         expression="document.dynamic.userdefined.onHand > 0"/>

  <shape id="connector_ecom_post"
         name="POST CatalogItem to Storefront API"
         type="connectorAction"
         shapeType="connector.http"
         action="SEND"
         url="https://api.shop.acmecorp.com/v2/catalog/items"
         method="POST"
         contentType="application/json"
         authType="OAUTH2"
         oauthConnection="storefront-api-oauth"
         retryOnFail="true"
         retryAttempts="3"/>

  <shape id="connector_ecom_archive"
         name="POST Out-of-Stock to Archive Index"
         type="connectorAction"
         shapeType="connector.http"
         action="SEND"
         url="https://api.shop.acmecorp.com/v2/catalog/archive"
         method="POST"
         contentType="application/json"/>

  <shape id="notify_summary"
         name="Email Run Summary"
         type="notify"
         level="INFO"
         message="Partner catalog sync complete. Items processed: $document.count"
         emailRecipients="merchandising-ops@acmecorp.com"/>

  <connection source="start_scheduler"            target="connector_sftp_get"/>
  <connection source="connector_sftp_get"         target="data_process_split"/>
  <connection source="data_process_split"         target="data_process_xml_to_profile"/>
  <connection source="data_process_xml_to_profile" target="map_xml_to_json"/>
  <connection source="map_xml_to_json"            target="decision_in_stock"/>
  <connection source="decision_in_stock"          target="connector_ecom_post"    label="true"/>
  <connection source="decision_in_stock"          target="connector_ecom_archive" label="false"/>
  <connection source="connector_ecom_post"        target="notify_summary"/>
  <connection source="connector_ecom_archive"     target="notify_summary"/>

</process>
